{
  "name": "Mini-Games",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "GameStatus": {
        "$className": "StringValue"
      },
      "Events": {
        "$className": "Folder",
        "LowGravity": { "$className": "RemoteEvent" },
        "AfkMode": { "$className": "RemoteEvent" },
        "ItemPurchased": { "$className": "RemoteFunction" },
        "UpdateVotes": { "$className": "RemoteFunction" },
        "Voting": { "$className": "RemoteEvent" },
        "MinigameChosen": { "$className": "RemoteEvent" }
      }
    },

    "ServerScriptService": {
      "ShopHandler": { "$path": "src/server/ShopHandler.server.lua" },
      "GameHandler": { "$path": "src/server/GameHandler.server.lua" },
      "AfkHandler": { "$path": "src/server/AfkHandler.server.lua" },
      "leaderstats": { "$path": "src/server/Leaderstatus.server.lua" }
    },

    "ServerStorage": {
      "Items": {
        "$className": "Folder",
        "FIRE": { "$className": "ParticleEmitter" },
        "ICE": { "$className": "ParticleEmitter" }
      },

      "Powers": {
        "$path": "src/server/Powers.luau",
        "LowGravity": { "$className": "ParticleEmitter" },
        "ExtraSpeed": { "$className": "ParticleEmitter" }
      },

      "KillFunction": { "$path": "src/server/KillFunction.luau" },
      "BasicEnding": { "$path": "src/server/BasicEnding.luau" },
      "TeleportPlayers": { "$path": "src/server/TeleportPlayers.luau" },

      "MiniGames": {
        "$className": "Folder",

        "Capture The Flag": {
          "$path": "src/server/Capture The Flag.luau",
          "GameModel": {
            "$className": "Folder",
            "Flags": { "$className": "Folder" },
            "Markers": { "$className": "Folder" },
            "Rocks": { "$className": "Model" },
            "Walls": { "$className": "Model" },
            "Base": { "$className": "Part" },
            "BlueSpawn": { "$className": "Part" },
            "RedSpawn": { "$className": "Part" }
          },
          "ClassicSword": {
            "$className": "Tool",
            "SwordScript": { "$path": "src/server/SwordScript.server.lua" },
            "MouseIcon": { "$path": "src/client/MouseIcon.client.lua" },
            "Handle": {
              "$className": "Part",
              "SwordLunge": { "$className": "Sound" },
              "SwordSlash": { "$className": "Sound" },
              "Unsheath": { "$className": "Sound" },
              "Mesh": { "$className": "SpecialMesh" }
            }
          },
          "FlaggedMarker": {
            "$className": "BillboardGui",
            "MainFrame": { "$className": "Frame" }
          }
        },

        "Lava Rising": {
          "$path": "src/server/LavaRising.luau",
          "GameModel": { "$className": "Folder" }
        },

        "Infection Tag": {
          "$path": "src/server/Infection Tag.luau"
        },

        "Crazy Colors": {
          "$path": "src/server/CrazyColors.luau",
          "GameModel": { "$className": "Folder" }
        },

        "Tile Dash": {
          "$path": "src/server/Tile Dash.luau",
          "GameModel": {
            "$className": "Folder",
            "Lava": { "$className": "Part" },
            "Spawn": { "$className": "Part" },
            "Tiles": { "$className": "Folder" }
          }
        },

        "Spleef": {
          "$path": "src/server/Spleef.luau",
          "GameModel": {
            "$className": "Folder",
            "Levels": {
              "$className": "Folder",
              "Level": { "$className": "Model" }
            },
            "KillBrick": { "$className": "Part" },
            "SpawnPoint": { "$className": "Part" }
          }
        }
      }
    },

    "StarterGui": {
      "RuboxShop": {
        "$className": "ScreenGui",
        "MainFrame": {
          "$className": "Frame",
          "Header": {
            "$className": "Frame",
            "Title": {
              "$className": "TextLabel"
            },
            "Icon": {
              "$className": "ImageLabel"
            },
            "CloseButton": {
              "$className": "ImageButton"
            }
          },
          "TabBar": {
            "$className": "Frame",
            "ScrollFrame": {
              "$className": "ScrollFrame",
              "BigCardTemplate1": {
                "$className": "Frame",
                "Tile": {
                  "$className": "TextLabel"
                },
                "Description": {
                  "$className": "TextLabel"
                },
                "Icon": {
                  "$className": "ImageLabel"
                },
                "Price": {
                  "$className": "TextLabel",
                  "RuboxIcon": {
                    "$className": "ImageLabel"
                  }
                },
                "BuyButton": {
                  "$className": "ImageButton"
                }
              },
              "TitleFrameTemplate": {
                "$className": "Frame",
                "Title": {
                  "$className": "TextLabel"
                }
              },
              "BigCardTemplate2": {
                "$className": "Frame",
                "Tile": {
                  "$className": "TextLabel"
                },
                "Description": {
                  "$className": "TextLabel"
                },
                "Icon": {
                  "$className": "ImageLabel"
                },
                "Price1": {
                  "$className": "TextLabel",
                  "RuboxIcon": {
                    "$className": "ImageLabel"
                  }
                },
                "Price2": {
                  "$className": "TextLabel",
                  "RuboxIcon": {
                    "$className": "ImageLabel"
                  }
                },
                "Price3": {
                  "$className": "TextLabel",
                  "RuboxIcon": {
                    "$className": "ImageLabel"
                  }
                },
                "BuyButton1": {
                  "$className": "ImageButton"
                },
                "BuyButton2": {
                  "$className": "ImageButton"
                },
                "BuyButton3": {
                  "$className": "ImageButton"
                }
              },
              "SmallCardTemplate2": {
                "$className": "Frame",
                "Title": {
                  "$className": "TextLabel"
                },
                "Price": {
                  "$className": "TextLabel",
                  "RuboxIcon": {
                    "$className": "ImageLabel"
                  }
                },
                "BuyButton": {
                  "$className": "ImageButton"
                }
              }
            }
          }
        }
      },
      "VotingFrame": {
        "$className": "ScreenGui",
        "MainFrame": {
          "$className": "Frame",
          "VotingClient": {
            "$path": "src/client/VotingClient.client.lua",
            "Selected": { "$className": "Frame" }
          },
          "Columns": {
            "$className": "Frame",
            "ImageButton": { "$className": "ImageButton" }
          }
        }
      },

      "ShopGui": {
        "$className": "ScreenGui",
        "ShopGui": {
          "$path": "src/client/ShopGui.client.lua"
        }
      },

      "Stats": {
        "$className": "ScreenGui",
        "StatusUpdater": {
          "$path": "src/client/StatusUpdaterWins.client.lua"
        },
        "Wins": {
          "$className": "Frame",
          "WinsIcon": {
            "$className": "ImageLabel",
            "UIAspectRatioConstraint": {
              "$className": "UIAspectRatioConstraint"
            }
          },
          "WinsLabel": { "$className": "TextLabel" }
        }
      },

      "StatusGui": {
        "$className": "ScreenGui",
        "StatusLabel": { "$className": "TextLabel" },
        "StatusUpdater": {
          "$path": "src/client/StatusUpdater.client.lua"
        }
      },

      "AfkMode": {
        "$className": "ScreenGui",
        "AfkGui": {
          "$path": "src/client/AfkGui.client.lua"
        },
        "AfkButton": {
          "$className": "TextButton",
          "AfkStatus": { "$className": "TextLabel" }
        }
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "LowGravity": {
          "$path": "src/client/LowGravity.client.lua"
        }
      }
    },

    "Workspace": {},
    "Lighting": {},
    "SoundService": {}
  }
}